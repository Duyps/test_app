// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// ==========================================
// CẤU HÌNH KẾT NỐI DATABASE
// ==========================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ĐỊNH NGHĨA CÁC BẢNG (MODELS)
// ==========================================

// 1. Bảng USER (Chỉ giữ thông tin định danh & bảo mật)
model User {
  user_id    String    @id @default(uuid()) @db.VarChar(50)
  email      String    @unique @db.VarChar(100)
  password   String?   @db.VarChar(100)
  
  // Họ tên chính của tài khoản
  full_name  String    @default("Người dùng vô danh") @db.VarChar(100)

  reset_otp       String?   @db.VarChar(6)
  otp_expires_at  DateTime?
  
  created_at DateTime? @default(now())

  // Quan hệ
  health_profile HealthProfile?
  relatives      Relative[]
  devices        Device[]
  workout_sessions WorkoutSession[]
  health_metrics   HealthMetric[]
  alert_logs       AlertLog[]

  @@map("user")
}

// 2. Bảng HEALTH_PROFILE (Cập nhật để khớp với Frontend Edit Screen)
model HealthProfile {
  profile_id   String    @id @default(uuid()) @db.VarChar(50)
  user_id      String    @unique @db.VarChar(50)
  
  // Thông tin vật lý
  height       Float?
  weight       Float?
  
  // Đổi từ Boolean sang String để lưu 'male', 'female', 'other'
  gender       String?   @db.VarChar(20) 
  
  // Dùng tên 'birth' đồng nhất (hoặc date_of_birth tùy bạn chọn nhưng phải nhất quán)
  birth        DateTime? @db.Date 
  
  // Thêm các trường bạn đang dùng trong Edit Screen
  phone_number String?   @db.VarChar(20)
  blood_type   String?   @db.VarChar(10)
  
  // Huyết áp (nếu bạn vẫn muốn giữ)
  systolic_bp  Int? 
  diastolic_bp Int? 
  
  updated_at   DateTime? @updatedAt

  // Quan hệ
  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("health_profile")
}

// 3. Bảng RELATIVE (Người thân khẩn cấp)
model Relative {
  phone_num    String  @db.VarChar(20)
  user_id      String @db.VarChar(50)
  contact_name String  @db.VarChar(100)
  relationship String @db.VarChar(50)
  relative_id  String  @id @default(dbgenerated("gen_random_uuid()::varchar")) @db.VarChar(50)

  user User? @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("relative")
}

// 4. Bảng DEVICE (Thiết bị/Nguồn dữ liệu)
model Device {
  device_id      String    @id @db.VarChar(50)
  user_id        String?   @db.VarChar(50)
  provider       String    @db.VarChar(50) // vd: 'health_connect', 'fitbit'
  status         String?   @db.VarChar(20)
  last_sync_time DateTime @default(now())

  user User? @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("device")
}

// 5. Bảng WORKOUT_SESSION (Buổi tập luyện)
model WorkoutSession {
  work_id        String    @id @default(uuid()) @db.VarChar(50)
  user_id        String?   @db.VarChar(50)
  start_time     DateTime
  end_time       DateTime?
  max_heart_rate Int?
  av_heart_rate  Int?
  status         String?   @db.VarChar(20)

  user           User?          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  health_metrics HealthMetric[]
  alert_logs     AlertLog[]

  @@map("workout_session")
}

// 6. Bảng HEALTH_METRIC (Kho chứa dữ liệu khổng lồ)
model HealthMetric {
  health_id      String   @id @default(uuid()) @db.VarChar(50)
  user_id        String?  @db.VarChar(50)
  work_id        String?  @db.VarChar(50)
  record_time    DateTime
  heart_rate     Int?
  steps          Int?
  sleep_duration Int? // Đơn vị: Phút
  stress_level   Int?
  raw_data       Json? // Dữ liệu JSON linh hoạt (SpO2, HRV...)

  user            User?           @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  workout_session WorkoutSession? @relation(fields: [work_id], references: [work_id], onDelete: SetNull)

  @@map("health_metric")
}

// 7. Bảng ALERT_LOG (Nhật ký cảnh báo)
model AlertLog {
  alert_id           String   @id @default(uuid()) @db.VarChar(50)
  user_id            String?  @db.VarChar(50)
  work_id            String?  @db.VarChar(50)
  type               String   @db.VarChar(50)
  trigger_heart_rate Int
  alert_time         DateTime
  is_sos_sent        Boolean? @default(false)

  user            User?           @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  workout_session WorkoutSession? @relation(fields: [work_id], references: [work_id], onDelete: SetNull)

  @@map("alert_log")
}
